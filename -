// Define keyframe animations for filtering
const PortfolioAnimations = () => {
  return (
    <style
      dangerouslySetInnerHTML={{
        __html: `
        @keyframes portfolioItemIn {
          0% {
            opacity: 0;
            transform: scale(0.9);
          }
          100% {
            opacity: 1;
            transform: scale(1);
          }
        }
        
        @keyframes portfolioItemSlideIn {
          0% {
            opacity: 0;
            transform: translateY(20px);
          }
          100% {
            opacity: 1;
            transform: translateY(0);
