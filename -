export interface ProfileCardProps {
  /** User's name */
  name: string;
  /** User's role or title */
  role?: string;
  /** User's profile image URL */
  imageUrl?: string;
  /** User's initials (used as fallback when image is not available) */
  initials?: string;
  /** Short bio or description */
  bio?: string;
