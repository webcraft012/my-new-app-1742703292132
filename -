import { exec } from 'child_process';
import { promisify } from 'util';
import { VultrClient } from './VultrClient';

const execAsync = promisify(exec);

// Type definition for Vultr instance
interface VultrInstance {
  id: string;
  os: string;
  ram: number;
  disk: number;
  main_ip: string;
  vcpu_count: number;
  region: string;
  status: string;
  hostname: string;
